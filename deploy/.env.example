# deploy/.env  — 프로덕션 시크릿/설정. 이 파일을 .env 로 복사해 채우세요. (절대 커밋 금지)
#   cp .env.example .env

# ── 도메인 ───────────────────────────────────────────────
# 도메인이 아직 없으면 무료 서브도메인으로 시작 가능(예: DuckDNS).
# 이 도메인의 A 레코드가 VM 공인 IP 를 가리켜야 HTTPS 발급이 됩니다.
DOMAIN=worlddeveloper.duckdns.org

# ── 시크릿 (직접 생성) ───────────────────────────────────
# 생성:  openssl rand -base64 48   (JWT 는 최소 32바이트)
JWT_SECRET=__CHANGE_ME__min_32_bytes__
# 생성:  openssl rand -base64 32   (web↔backend 내부 호출 인증, 양쪽 동일해야 함)
INTERNAL_AUTH_SECRET=__CHANGE_ME__
# Postgres 비밀번호 (자유 설정)
POSTGRES_PASSWORD=__CHANGE_ME__

# ── OpenAI (선택) ───────────────────────────────────────
# 공고 한국어 요약 + 이력서 코치(gpt-4o-mini). 없으면 해당 기능만 비활성.
# ETL 수집 자체는 키 없이도 무료로 동작.
OPENAI_API_KEY=

# ── JSearch (선택, RapidAPI) ────────────────────────────
# LinkedIn/Indeed/Glassdoor 보강 수집. 없으면 JSearch 소스만 비활성.
# https://rapidapi.com 가입 → JSearch 구독 → X-RapidAPI-Key. 무료 플랜 한도 주의.
RAPIDAPI_KEY=

# ── OAuth (선택) ────────────────────────────────────────
# 없으면 소셜 로그인만 비활성(이메일 가입/로그인은 정상).
# 콜백 URL: https://<DOMAIN>/login/oauth2/code/github , .../google
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 메일 SMTP (선택) ────────────────────────────────────
# 미설정 시 이메일 인증 링크가 backend 로그(docker compose logs backend)로 출력됨.
# 예: Gmail 앱 비밀번호 → MAIL_HOST=smtp.gmail.com MAIL_PORT=587
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=no-reply@worlddeveloper.duckdns.org

# ── 로고 (선택, 빌드시점) ───────────────────────────────
# logo.dev 토큰. 없으면 회사 이니셜 폴백.
NEXT_PUBLIC_LOGODEV_TOKEN=
