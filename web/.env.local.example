# Spring 백엔드 (web 서버사이드 프록시 대상)
BACKEND_URL=http://localhost:8080

# 브라우저가 OAuth 시작 시 직접 접근하는 Spring 공개 URL
BACKEND_PUBLIC_URL=http://localhost:8080

# 백엔드와 공유하는 JWT 서명 시크릿 (백엔드 JWT_SECRET 과 동일, 최소 32바이트)
# — middleware 가 이 시크릿으로 세션 쿠키(Spring 발급 JWT)를 검증한다
JWT_SECRET=dev-local-jwt-secret-change-me-min-32-bytes!!

# 백엔드와 공유하는 내부 시크릿 (OAuth code 교환; 백엔드 INTERNAL_AUTH_SECRET 과 동일)
INTERNAL_AUTH_SECRET=dev-internal-secret-change-me

# web 공개 URL (로그아웃/OAuth 콜백 리다이렉트 base)
APP_BASE_URL=http://localhost:3000

# 참고: OAuth Client ID/Secret(GitHub/Google)은 이제 web 이 아니라 백엔드 env 에 둔다
# (Spring Security oauth2-client 가 OAuth 흐름을 처리). .env.example(루트) 참고.
